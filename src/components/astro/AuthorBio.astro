---
// Author bio block for Learn Hub articles.
// Renders below the meta line, above the medical disclaimer.
// Variant-driven: 'consumer' for /learn/* articles, 'pro' for /pro/learn/*.
// NEVER renders Cody's photo (per CLAUDE.md constraint).
// Uses brand mark / icon avatar from src/data/authors.ts.

import { authors, defaultAuthorId, type AuthorBioVariant } from '@/data/authors';

interface Props {
  variant?: AuthorBioVariant;
  authorId?: string;
}

const { variant = 'consumer', authorId = defaultAuthorId } = Astro.props;
const author = authors[authorId];

if (!author) {
  throw new Error(`AuthorBio: unknown authorId "${authorId}". Add to src/data/authors.ts.`);
}
---

<aside
  class="not-prose my-8 rounded-lg border bg-secondary/40 p-5"
  aria-labelledby={`author-bio-${author.id}-heading`}
>
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0">
      <img
        src={author.avatar}
        alt={author.avatarAlt}
        width="56"
        height="56"
        class="h-14 w-14 rounded-full bg-background object-contain p-2 ring-1 ring-border"
        loading="lazy"
      />
    </div>
    <div class="flex-1 text-sm">
      <h2 id={`author-bio-${author.id}-heading`} class="text-base font-semibold text-foreground">
        About the author
      </h2>
      <p class="mt-1 font-medium text-foreground">
        {author.name}<span class="text-muted-foreground"> · {author.role}</span>
      </p>
      <p class="mt-2 text-muted-foreground">{author.body[variant]}</p>
      <p class="mt-3 italic text-muted-foreground">{author.disclosure[variant]}</p>
      <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs">
        {author.links.map((link) => (
          <li>
            <a class="text-primary hover:underline" href={link.href}>
              → {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>
