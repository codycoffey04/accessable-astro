---
interface Props {
  title: string;
  description: string;
  showFDADisclaimer?: boolean;
  conditionSlug?: string;
}

const { title, description, showFDADisclaimer = false, conditionSlug } = Astro.props;
---

<section class="py-12 bg-muted/40">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      {showFDADisclaimer && (
        <div class="mb-8 rounded-lg border border-amber-200 bg-amber-50 p-6">
          <div class="flex gap-3">
            <svg class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-amber-900 mb-2">
                Important Medical Disclaimer
              </p>
              <p class="text-sm text-amber-800">
                These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease.
                {conditionSlug === 'post-surgery' && ' Follow your healthcare provider\'s post-surgical guidance.'}
                <a href="/policies/fda-disclaimer" class="underline ml-1">Full Policy</a>
              </p>
            </div>
          </div>
        </div>
      )}

      <h1 class="text-3xl lg:text-4xl font-bold text-[#1B2A4A] mb-4">{title}</h1>
      <p class="text-lg text-muted-foreground max-w-2xl">{description}</p>
    </div>
  </div>
</section>
