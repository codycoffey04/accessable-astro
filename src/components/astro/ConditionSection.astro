---
import type { ConditionType } from '@/data/conditionContent';
import {
  conditionContent,
  conditionRecommendations,
  relatedArticles,
  customerStories,
  storiesHeading,
  challengesHeading,
  tipsHeading,
  compressionContextHeading,
  caregiverSubheading,
} from '@/data/conditionContent';
import MedicalDisclaimer from '@/components/astro/MedicalDisclaimer.astro';

interface Props {
  condition: ConditionType;
}

const { condition } = Astro.props;
const content = conditionContent[condition];
const recommendations = conditionRecommendations[condition];
const articles = relatedArticles[condition] || [];
const stories = customerStories[condition] || [];
---

{content && (
  <>
    <!-- Education Section -->
    <section class="py-12 bg-muted/40" aria-labelledby="education-heading">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 id="education-heading" class="text-3xl font-bold mb-6">{content.headline}</h2>

          <!-- Educational Content -->
          <div class="space-y-6 text-lg text-muted-foreground">
            {content.educationalContent.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <!-- Video Placeholder -->
          <div class="my-8">
            <div class="aspect-video bg-muted rounded-lg flex items-center justify-center">
              <div class="text-center p-8">
                <p class="font-medium mb-2">[Video: {content.educationalContent.videoTitle}]</p>
                <p class="text-sm text-muted-foreground">
                  Accessibility Requirements: Captions (WebVTT), Full Transcript (PDF), Audio Description
                </p>
              </div>
            </div>
          </div>

          <!-- Source Citation -->
          {content.educationalContent.sourceCitation && (
            <div class="mb-8 pt-6 border-t">
              <p class="text-sm text-muted-foreground">
                <strong>Source Citation:</strong>{' '}
                <a
                  href={content.educationalContent.sourceCitation.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  {content.educationalContent.sourceCitation.text}
                </a>
              </p>
            </div>
          )}

          <!-- Challenges -->
          {content.challenges.length > 0 && (
            <div class="my-12">
              <h3 class="text-2xl font-bold mb-6">{challengesHeading[condition]}</h3>
              <p class="text-lg text-muted-foreground mb-6">Daily-Life Friction Points</p>
              <div class="space-y-6">
                {content.challenges.map((challenge) => (
                  <div class="rounded-lg border bg-card shadow-sm border-l-4 border-l-primary p-6">
                    <h4 class="font-semibold text-lg mb-2">{challenge.title}</h4>
                    <p class="text-muted-foreground">{challenge.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- How Compression & Adaptive Tools Help -->
          {content.howItHelps.whyCompression && (
            <div class="my-12">
              <h3 class="text-2xl font-bold mb-6">How Compression & Adaptive Tools Help</h3>
              <p class="text-sm font-medium text-muted-foreground mb-4">Educational Context (Not Medical Claims)</p>

              <div class="space-y-6">
                <div>
                  <h4 class="font-semibold mb-3">{compressionContextHeading[condition]}:</h4>
                  <p class="text-muted-foreground">{content.howItHelps.whyCompression}</p>
                </div>

                <div>
                  <h4 class="font-semibold mb-3">What adaptive features do:</h4>
                  <p class="text-muted-foreground mb-4">{content.howItHelps.whatAdaptiveFeatures}</p>

                  <ul class="space-y-3 list-disc list-inside ml-4">
                    {content.howItHelps.features.map((f) => (
                      <li class="text-muted-foreground">
                        <strong>{f.feature}</strong> &ndash; {f.description}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="rounded-lg border bg-muted/50 border-primary/20 p-6">
                  <p class="text-sm text-muted-foreground italic">{content.howItHelps.disclaimer}</p>
                </div>
              </div>
            </div>
          )}

          <!-- Practical Tips -->
          {content.practicalTips.length > 0 && (
            <div class="my-12">
              <h3 class="text-2xl font-bold mb-6">{tipsHeading[condition]}</h3>
              <p class="text-sm font-medium text-muted-foreground mb-6">Daily Strategies (Not Medical Advice)</p>
              <div class="space-y-4">
                {content.practicalTips.map((tip) => (
                  <div class="rounded-lg border bg-card shadow-sm p-6">
                    <h4 class="font-semibold mb-2">{tip.title}</h4>
                    <p class="text-muted-foreground">{tip.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Caregiver Notes -->
          {content.caregiverNotes && content.caregiverNotes.length > 0 && (
            <div class="my-12">
              <h3 class="text-2xl font-bold mb-6">Caregiver Notes</h3>
              <p class="text-lg text-muted-foreground mb-6">{caregiverSubheading[condition]}</p>
              <div class="space-y-4">
                {content.caregiverNotes.map((note) => (
                  <div class="rounded-lg border bg-card shadow-sm p-6">
                    <h4 class="font-semibold mb-2">{note.title}</h4>
                    <p class="text-muted-foreground">{note.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- FAQs (native details/summary) -->
          {content.faqs.length > 0 && (
            <div class="my-12">
              <h3 class="text-2xl font-bold mb-6">Frequently Asked Questions</h3>
              <div class="divide-y">
                {content.faqs.map((faq) => (
                  <details class="group py-4">
                    <summary class="flex cursor-pointer items-center justify-between text-left font-semibold hover:text-primary transition-colors">
                      {faq.question}
                      <svg class="h-4 w-4 flex-shrink-0 transition-transform group-open:rotate-180 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </summary>
                    <p class="mt-3 text-muted-foreground pr-8">{faq.answer}</p>
                  </details>
                ))}
              </div>
            </div>
          )}

          <MedicalDisclaimer />
        </div>
      </div>
    </section>

    <!-- Recommendations -->
    {recommendations && (
      <section class="py-12 container mx-auto px-4" aria-labelledby="recommendations-heading">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h2 id="recommendations-heading" class="text-3xl font-bold mb-4">
              Recommended AccessAble Products
            </h2>
          </div>

          <!-- Primary Recommendation -->
          {recommendations.primary && (
            <div class="mb-12">
              <div class="rounded-lg border border-primary/20 bg-primary/5 p-8">
                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-primary text-primary-foreground mb-4">Primary Recommendation</span>
                <h3 class="text-2xl font-bold mb-4">{recommendations.primary.title}</h3>
                <p class="text-lg text-muted-foreground mb-6">
                  <strong>Why this helps:</strong> {recommendations.primary.whyHelps}
                </p>
                <div class="mb-6">
                  <h4 class="font-semibold mb-3">Key Features:</h4>
                  <ul class="space-y-2">
                    {recommendations.primary.keyFeatures.map((feature) => (
                      <li class="flex items-start gap-2">
                        <svg class="h-5 w-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-muted-foreground">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <a
                  href="https://signup.accessablecompression.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8"
                >
                  {recommendations.primary.ctaText}
                </a>
              </div>
            </div>
          )}

          <!-- Secondary Recommendation -->
          {recommendations.secondary && (
            <div class="mb-12">
              <div class="rounded-lg border bg-card p-8">
                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold mb-4">Secondary Recommendation</span>
                <h3 class="text-2xl font-bold mb-4">{recommendations.secondary.title}</h3>
                <p class="text-lg text-muted-foreground mb-6">
                  <strong>Why these are different:</strong> {recommendations.secondary.whyDifferent}
                </p>
                <div class="mb-6">
                  <h4 class="font-semibold mb-3">Key Features:</h4>
                  <ul class="space-y-2">
                    {recommendations.secondary.keyFeatures.map((feature) => (
                      <li class="flex items-start gap-2">
                        <svg class="h-5 w-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-muted-foreground">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <a
                  href={recommendations.secondary.ctaLink}
                  class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-8"
                >
                  {recommendations.secondary.ctaText}
                </a>
              </div>
            </div>
          )}

          <!-- Complete Solution Bundle -->
          {recommendations.completeSolution && (
            <div class="mb-12">
              <div class="rounded-lg border border-primary bg-primary/10 p-8">
                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-primary text-primary-foreground mb-4">Complete Solution</span>
                <h3 class="text-2xl font-bold mb-4">{recommendations.completeSolution.title}</h3>
                <div class="mb-6">
                  <h4 class="font-semibold mb-3">What's Included:</h4>
                  <ul class="space-y-2">
                    {recommendations.completeSolution.whatsIncluded.map((item) => (
                      <li class="flex items-start gap-2">
                        <svg class="h-5 w-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-muted-foreground">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <p class="text-lg text-muted-foreground mb-4">
                  <strong>Why a bundle:</strong> {recommendations.completeSolution.whyBundle}
                </p>
                <a
                  href="https://signup.accessablecompression.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8 w-full sm:w-auto"
                >
                  {recommendations.completeSolution.ctaText} | {recommendations.completeSolution.savings}
                </a>
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Related Guides -->
    {articles.length > 0 && (
      <section class="py-12 bg-muted/40">
        <div class="container mx-auto px-4">
          <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold mb-4 text-center">You Might Find These Helpful</h2>
            <p class="text-center text-muted-foreground mb-8">Expert guides for independent living</p>

            <div class="grid md:grid-cols-3 gap-6">
              {articles.map((article) => (
                <div class="rounded-lg border bg-card shadow-sm overflow-hidden group hover:border-primary/50 transition-colors">
                  <div class="aspect-video bg-muted"></div>
                  <div class="p-6">
                    <div class="flex items-center gap-2 mb-3">
                      <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-sm text-muted-foreground">{article.readTime}</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2 group-hover:text-primary transition-colors">
                      {article.title}
                    </h3>
                    <p class="text-sm text-muted-foreground mb-4">{article.excerpt}</p>
                    <a href={`/learn/${article.slug}`} class="text-sm font-medium text-primary hover:underline">
                      Read Article
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <div class="text-center mt-8">
              <a href="/learn" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2">
                Browse All Guides
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Customer Stories -->
    {stories.length > 0 && (
      <section class="py-12 container mx-auto px-4" aria-labelledby="stories-heading">
        <div class="max-w-6xl mx-auto">
          <h2 id="stories-heading" class="text-3xl font-bold mb-4 text-center">
            {storiesHeading[condition]}
          </h2>
          <p class="text-center text-muted-foreground mb-8">
            Hear from people who prioritize independence
          </p>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {stories.map((story) => (
              <div class="rounded-lg border bg-card shadow-sm hover:border-primary/50 transition-colors p-6">
                <!-- Avatar -->
                <div class="w-16 h-16 rounded-full bg-muted mb-4 flex items-center justify-center">
                  <span class="text-2xl font-bold text-muted-foreground">{story.name.charAt(0)}</span>
                </div>

                <!-- Rating -->
                <div class="flex gap-1 mb-3" aria-label={`${story.rating} out of 5 stars`}>
                  {Array.from({ length: story.rating }).map(() => (
                    <svg class="h-4 w-4 fill-primary text-primary" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <p class="text-muted-foreground mb-4 italic">"{story.quote}"</p>

                <!-- User Info -->
                <p class="font-medium">{story.name}</p>
                <p class="text-sm text-muted-foreground">{story.userType}</p>
              </div>
            ))}
          </div>

          <div class="mt-8 p-6 bg-muted/50 rounded-lg">
            <p class="text-sm text-muted-foreground text-center">
              <strong>Compliance Note:</strong> All testimonials focus on functional benefits (ease of use, comfort, fit) and avoid medical claims.
              No statements about pain relief, circulation improvement, or symptom reduction are included.
            </p>
          </div>
        </div>
      </section>
    )}
  </>
)}
