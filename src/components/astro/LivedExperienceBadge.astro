---
// Compact lived-experience credential pill for the article meta row.
// Distinct from LivedExperienceCallout (which is a longer body-content card).
// Renders on every condition-specific, donning, and Pro article.
---

<span
  role="img"
  class="inline-flex items-center gap-1.5 rounded-full border border-primary/30 bg-primary/5 px-2.5 py-0.5 text-xs font-medium text-primary"
  aria-label="Author has lived experience with C4 spinal cord injury"
>
  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="6" r="2" stroke-linecap="round" stroke-linejoin="round" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 21l4-7m6 7l-4-7m-2 0v-5a3 3 0 116 0v5" />
  </svg>
  Lived experience · C4 SCI
</span>
