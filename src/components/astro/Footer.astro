---
import siteData from '@/content/site.json';
// HighContrastToggle will be wired as a React island on Day 2
// For now, the toggle works via the inline script in BaseLayout

const shopLinks = [
  { href: '/collections/compression-socks', label: 'Compression Socks' },
  { href: '/collections/donnease', label: 'DonnEase\u2122 Socks' },
  { href: '/collections/bundles', label: 'Bundles' },
  { href: '/collections/all', label: 'All Products' },
];

const learnLinks = [
  { href: '/learn/mobility-aids', label: 'Mobility Guides' },
  { href: '/learn/compression-101', label: 'Compression Basics' },
  { href: '/learn', label: 'Condition Pages' },
  { href: '/learn', label: 'All Articles' },
];

const companyLinks = [
  { href: '/about', label: 'Our Story' },
  { href: '/pro', label: 'AccessAble Pro' },
  { href: '/contact', label: 'Contact' },
  { href: '/policies/accessibility', label: 'Accessibility Statement' },
];

const legalLinks = [
  { href: '/policies/privacy', label: 'Privacy Policy' },
  { href: '/policies/terms', label: 'Terms of Service' },
  { href: '/policies/shipping-returns', label: 'Shipping & Returns' },
  { href: '/policies/fda-disclaimer', label: 'FDA Disclaimer' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#1B2A4A] border-t-2 border-[#C9A84C] mt-auto">
  <!-- ROW 1 — Main Content -->
  <div class="container mx-auto px-4 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.7fr_1fr_1fr_1fr_1fr] gap-8 lg:gap-6">
      <!-- Brand Column -->
      <div class="md:col-span-2 lg:col-span-1 space-y-4">
        <a href="/" class="flex items-center gap-2.5" aria-label="AccessAble Home">
          <img src="/images/ac-logo.png" alt="" class="h-12 w-auto object-contain brightness-0 invert" />
          <span class="text-[28px] font-bold text-white" style="font-family: 'Playfair Display', Georgia, serif; letter-spacing: -0.02em;">
            AccessAble
          </span>
        </a>
        <p class="text-white/75 text-sm leading-relaxed">{siteData.tagline}</p>
        <p class="text-white/75 text-xs">{siteData.founderNote}</p>
        <a
          href={`mailto:${siteData.email}`}
          class="flex items-center gap-2 text-white/85 hover:text-white transition-colors text-sm"
        >
          <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {siteData.email}
        </a>
        <div class="flex items-center gap-3 pt-1">
          <a href={siteData.social.facebook} aria-label="Facebook" class="text-white/75 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
          </a>
          <a href={siteData.social.instagram} aria-label="Instagram" class="text-white/75 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" /></svg>
          </a>
        </div>
      </div>

      <!-- Shop Column -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4 text-[#C9A84C]">Shop</h3>
        <ul class="space-y-2.5">
          {shopLinks.map(link => (
            <li><a href={link.href} class="text-white/85 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Learn Column -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4 text-[#C9A84C]">Learn</h3>
        <ul class="space-y-2.5">
          {learnLinks.map(link => (
            <li><a href={link.href} class="text-white/85 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4 text-[#C9A84C]">Company</h3>
        <ul class="space-y-2.5">
          {companyLinks.map(link => (
            <li><a href={link.href} class="text-white/85 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4 text-[#C9A84C]">Legal</h3>
        <ul class="space-y-2.5">
          {legalLinks.map(link => (
            <li><a href={link.href} class="text-white/85 hover:text-white transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- ROW 2 — Trust Badges + High-Contrast Toggle -->
  <div class="border-t border-[#C9A84C]/30">
    <div class="container mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-wrap items-center gap-4 md:gap-6">
        <span class="flex items-center gap-1.5 text-white/60 text-xs">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          Made in USA
        </span>
        <span class="flex items-center gap-1.5 text-white/60 text-xs">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          FDA-Registered Facility
        </span>
        <span class="flex items-center gap-1.5 text-white/60 text-xs">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          Patent-Pending Technology
        </span>
      </div>
      <!-- High-contrast toggle (vanilla JS for now, React island later) -->
      <div class="flex items-center space-x-2">
        <button
          id="high-contrast-toggle"
          role="switch"
          aria-checked="false"
          aria-label="Toggle high contrast mode"
          class="relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-white/20 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#1B2A4A]"
        >
          <span class="pointer-events-none block h-4 w-4 rounded-full bg-white shadow-lg ring-0 transition-transform translate-x-0" id="high-contrast-thumb"></span>
        </button>
        <label for="high-contrast-toggle" class="cursor-pointer text-white/60 text-xs">
          High-Contrast Mode
        </label>
      </div>
    </div>
  </div>

  <!-- ROW 3 — Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-white/50">
      <p>&copy; {currentYear} AccessAble. All rights reserved.</p>
      <div class="flex items-center gap-3">
        <a href="/policies/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <span class="text-white/30">|</span>
        <a href="/policies/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // High-contrast toggle behavior
  const toggle = document.getElementById('high-contrast-toggle');
  const thumb = document.getElementById('high-contrast-thumb');
  const isActive = document.documentElement.classList.contains('high-contrast');

  if (isActive && toggle && thumb) {
    toggle.setAttribute('aria-checked', 'true');
    toggle.classList.add('bg-white/50');
    thumb.classList.add('translate-x-4');
    thumb.classList.remove('translate-x-0');
  }

  toggle?.addEventListener('click', () => {
    const nowActive = !document.documentElement.classList.contains('high-contrast');
    document.documentElement.classList.toggle('high-contrast');
    localStorage.setItem('high-contrast', nowActive.toString());
    toggle.setAttribute('aria-checked', nowActive.toString());
    if (thumb) {
      thumb.classList.toggle('translate-x-4', nowActive);
      thumb.classList.toggle('translate-x-0', !nowActive);
    }
    toggle.classList.toggle('bg-white/50', nowActive);
    toggle.classList.toggle('bg-white/20', !nowActive);
  });
</script>
