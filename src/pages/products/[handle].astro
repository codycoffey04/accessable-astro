---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import MedicalDisclaimer from '@/components/astro/MedicalDisclaimer.astro';
import ProductConfigurator from '@/components/islands/ProductConfigurator.tsx';
import { getProducts } from '@/lib/shopify';
import type { ShopifyProduct } from '@/lib/shopify';
import { getProductImages } from '@/data/productImages';
import { transformProductTitle } from '@/data/productTitleTransform';
import { PRODUCT_COPY_CONFIG } from '@/data/productCopy';
import type { ProductCopyConfig } from '@/data/productCopy';
import { generateProductSchema, generateBreadcrumbSchema } from '@/utils/schemaFactory';

export async function getStaticPaths() {
  let products: ShopifyProduct[] = [];
  try {
    products = await getProducts(50);
  } catch (e) {
    console.error('Failed to fetch products for static paths:', e);
  }

  return products.map((product) => ({
    params: { handle: product.node.handle },
    props: { product },
  }));
}

const { product } = Astro.props as { product: ShopifyProduct };
const handle = product.node.handle;
const displayTitle = transformProductTitle(product.node.title);
const productType = product.node.productType;

// Images with fallback
const images = getProductImages(
  product.node.images.edges,
  productType,
  handle,
  product.node.title,
);

// Product copy — fall back to Compression Socks config
const productCopy: ProductCopyConfig =
  PRODUCT_COPY_CONFIG[productType] ?? PRODUCT_COPY_CONFIG['Compression Socks'];

const isBundle = productType === 'Bundle';
const bundleConfig = isBundle && productCopy.bundles
  ? productCopy.bundles[handle as keyof typeof productCopy.bundles] ?? null
  : null;

// Price
const price = parseFloat(product.node.priceRange.minVariantPrice.amount).toFixed(2);

// Schemas
const SITE = 'https://accessablecompression.com';
const productSchema = generateProductSchema(product);
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: SITE },
  { name: 'Products', url: `${SITE}/collections/all` },
  { name: displayTitle, url: `${SITE}/products/${handle}` },
]);

const pageTitle = `${displayTitle} — AccessAble Adaptive Compression`;
const pageDescription = product.node.description?.substring(0, 155) || 'DonnEase\u2122 adaptive design. Free shipping & 30-day fit guarantee.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogType="product"
>
  <!-- Schema markup -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <nav class="container mx-auto px-4 py-4" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 text-sm">
      <li><a href="/" class="hover:text-[var(--color-primary)]">Home</a></li>
      <li>/</li>
      <li><a href="/collections/all" class="hover:text-[var(--color-primary)]">Products</a></li>
      <li>/</li>
      <li aria-current="page" class="text-gray-500">{displayTitle}</li>
    </ol>
  </nav>

  <div class="container mx-auto px-4 py-8">
    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Left: Image Gallery (static) -->
      <div class="space-y-4">
        <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden">
          <img
            src={images[0]?.node.url}
            alt={images[0]?.node.altText || displayTitle}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        {images.length > 1 && (
          <div class="grid grid-cols-5 gap-2">
            {images.map((img, idx) => (
              <div class="aspect-square rounded-md overflow-hidden border-2 border-transparent">
                <img
                  src={img.node.url}
                  alt={img.node.altText || `${displayTitle} - Image ${idx + 1}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Right: Product Info -->
      <div class="space-y-6">
        <div>
          <h1 class="text-3xl font-bold mb-2">{displayTitle}</h1>
          <p class="text-lg text-gray-500 mb-4">{productCopy.subheadline}</p>
          <div class="flex items-center gap-2 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 fill-[var(--color-primary)] text-[var(--color-primary)]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
            <span class="ml-1 text-sm text-gray-500">Ratings available after launch</span>
          </div>
        </div>

        <!-- Key Benefits -->
        <div>
          <h2 class="text-xl font-semibold mb-3">Key Benefits</h2>
          <ul class="space-y-2">
            {productCopy.keyBenefits.map((benefit) => (
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[var(--color-primary)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-gray-600">{benefit.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Supporting description -->
        <div class="space-y-3">
          {productType === 'Compression Socks' && (
            <h2 class="text-2xl font-bold">Built for All-Day Comfort and Independence</h2>
          )}
          <p class="text-gray-600">{productCopy.supportingDescription}</p>
        </div>

        <!-- FDA Disclaimer -->
        <div class="p-4 bg-gray-50 rounded-lg border">
          <p class="text-xs text-gray-500">
            These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease.{' '}
            <a href="/policies/fda-disclaimer" class="underline hover:text-gray-900">Full Policy &rarr;</a>
          </p>
        </div>

        <!-- Interactive variant selector + add to cart (React island) -->
        <ProductConfigurator
          client:visible
          product={product}
          productType={productType}
        />

        <!-- Accordions (static HTML with <details>) -->
        <div class="space-y-0 border-t">
          {/* How to Use — Compression Socks only */}
          {productType === 'Compression Socks' && (
            <details class="border-b group">
              <summary class="flex items-center justify-between py-4 cursor-pointer font-medium">
                How to Use
                <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="pb-4 space-y-4">
                <div class="space-y-3">
                  <h4 class="font-semibold">Step-by-Step Instructions:</h4>
                  <ol class="list-decimal list-inside space-y-2 text-gray-600">
                    <li>Sit comfortably with your leg bent at a 90-degree angle</li>
                    <li>Gather the sock at the heel, keeping the wide opening accessible</li>
                    <li>Slide your toes into the opening, then your foot</li>
                    <li>Use the built-in numbered markers to guide the sock up your leg</li>
                    <li>Adjust the sock so it sits smoothly without wrinkles</li>
                  </ol>
                </div>
              </div>
            </details>
          )}

          {/* Sizing & Fit — Compression Socks only */}
          {productType === 'Compression Socks' && (
            <details class="border-b group">
              <summary class="flex items-center justify-between py-4 cursor-pointer font-medium">
                Sizing & Fit
                <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="pb-4 space-y-4">
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b">
                        <th class="text-left p-2 font-semibold">Size</th>
                        <th class="text-left p-2 font-semibold">Calf Circumference</th>
                        <th class="text-left p-2 font-semibold">Ankle Circumference</th>
                        <th class="text-left p-2 font-semibold">Shoe Size (US Women's)</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr class="border-b"><td class="p-2 font-medium">S</td><td class="p-2">12-14"</td><td class="p-2">8-9"</td><td class="p-2">5-7</td></tr>
                      <tr class="border-b"><td class="p-2 font-medium">M</td><td class="p-2">14-16"</td><td class="p-2">9-10"</td><td class="p-2">7-9</td></tr>
                      <tr class="border-b"><td class="p-2 font-medium">L</td><td class="p-2">16-18"</td><td class="p-2">10-11"</td><td class="p-2">9-11</td></tr>
                      <tr class="border-b"><td class="p-2 font-medium">XL</td><td class="p-2">18-20"</td><td class="p-2">11-12"</td><td class="p-2">11-13</td></tr>
                      <tr><td class="p-2 font-medium">XXL</td><td class="p-2">20-22"</td><td class="p-2">12-13"</td><td class="p-2">13-15</td></tr>
                    </tbody>
                  </table>
                </div>
                <div class="bg-[var(--color-primary)]/5 p-4 rounded-lg border border-[var(--color-primary)]/20">
                  <p class="text-sm font-medium mb-2">30-Day Fit Guarantee</p>
                  <p class="text-sm text-gray-500">Not the right fit? Free exchanges within 30 days. Contact us and we'll send the correct size before you return the first pair.</p>
                </div>
              </div>
            </details>
          )}

          {/* Shipping & Returns */}
          <details class="border-b group">
            <summary class="flex items-center justify-between py-4 cursor-pointer font-medium">
              Shipping & Returns
              <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="pb-4 space-y-3">
              <div>
                <h4 class="font-semibold mb-2">Shipping</h4>
                <ul class="space-y-1 text-gray-600 text-sm">
                  <li>&bull; Free shipping on orders $50+</li>
                  <li>&bull; Standard shipping: 5-7 business days</li>
                  <li>&bull; Expedited options available at checkout (2-day and overnight)</li>
                  <li>&bull; International shipping available (rates calculated at checkout)</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold mb-2">Returns</h4>
                <ul class="space-y-1 text-gray-600 text-sm">
                  <li>&bull; 30-day return policy</li>
                  <li>&bull; Items must be unworn and in original packaging</li>
                  <li>&bull; Free exchanges for size issues</li>
                  <li>&bull; Return shipping costs apply (unless defective or wrong item sent)</li>
                </ul>
              </div>
              <a href="/policies/shipping-returns" class="text-[var(--color-primary)] underline text-sm">View Full Shipping & Returns Policy &rarr;</a>
            </div>
          </details>

          {/* FAQs */}
          {productCopy.faqs ? productCopy.faqs.map((faq) => (
            <details class="border-b group">
              <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">
                {faq.question}
                <svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="pb-4">
                <p class="text-gray-600">{faq.answer}</p>
              </div>
            </details>
          )) : (
            <>
              <details class="border-b group">
                <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">How long should I wear them each day?<svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary>
                <div class="pb-4"><p class="text-gray-600">Wear time depends on your individual needs and your provider's guidance. Many people wear compression socks during waking hours and remove them at night. Follow your healthcare provider's recommendations.</p></div>
              </details>
              <details class="border-b group">
                <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">Are these FSA/HSA eligible?<svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary>
                <div class="pb-4"><p class="text-gray-600">Yes. AccessAble compression socks are FSA/HSA eligible. Keep your receipt for reimbursement. Some insurance plans may also cover compression garments with a prescription -- check with your provider.</p></div>
              </details>
              <details class="border-b group">
                <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">How often should I replace them?<svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary>
                <div class="pb-4"><p class="text-gray-600">With daily wear and proper care, compression socks typically maintain their effectiveness for 3-6 months. Signs it's time to replace: reduced compression feel, visible fabric wear, or loss of elasticity.</p></div>
              </details>
              <details class="border-b group">
                <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">What if they don't fit?<svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary>
                <div class="pb-4"><p class="text-gray-600">We offer free exchanges within 30 days. Contact us and we'll send the correct size before you return the first pair. Our team can also help you remeasure if needed.</p></div>
              </details>
              <details class="border-b group">
                <summary class="flex items-center justify-between py-4 cursor-pointer font-medium text-left">Can I wear these with my brace/orthotic/prosthetic?<svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></summary>
                <div class="pb-4"><p class="text-gray-600">The design is compatible with most mobility aids and orthotics. The wide opening makes it easier to position around braces. If you have specific compatibility questions, chat with our team -- we're happy to help.</p></div>
              </details>
            </>
          )}
        </div>
      </div>
    </div>

    <!-- Below-fold Sections -->

    <!-- Bundle-specific: What's Included -->
    {isBundle && bundleConfig && (
      <section class="py-12 mt-12 bg-gray-50 -mx-4 px-4 rounded-lg">
        <div class="max-w-7xl mx-auto">
          <div class="flex items-center justify-center gap-3 mb-6">
            <h2 class="text-3xl font-bold">{bundleConfig.name}</h2>
            {bundleConfig.badge && (
              <span class="bg-[var(--color-primary)] text-white text-base px-3 py-1 rounded-full font-medium">{bundleConfig.badge}</span>
            )}
          </div>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="text-xl font-semibold mb-4">What's Included:</h3>
              <ul class="space-y-2">
                {bundleConfig.whatsIncluded.map((item) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-[var(--color-primary)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-gray-600">{item}</span>
                  </li>
                ))}
              </ul>
              {bundleConfig.customizationNote && (
                <p class="mt-4 text-sm text-gray-500 italic">{bundleConfig.customizationNote}</p>
              )}
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-4">Best for:</h3>
              <ul class="space-y-2">
                {bundleConfig.bestFor.map((item) => (
                  <li class="text-gray-600">&bull; {item}</li>
                ))}
              </ul>
              <div class="mt-6 p-4 bg-[var(--color-primary)]/5 rounded-lg border border-[var(--color-primary)]/20">
                <div class="flex justify-between items-baseline mb-2">
                  <span class="text-sm line-through text-gray-500">Separately: {bundleConfig.originalPrice}</span>
                  <span class="text-2xl font-bold text-[var(--color-primary)]">{bundleConfig.price}</span>
                </div>
                <p class="text-sm text-[var(--color-primary)] font-medium">{bundleConfig.savingsCallout}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Bundle: Why Bundle benefits grid -->
    {isBundle && productCopy.whyBundle && (
      <section class="py-16">
        <h2 class="text-3xl font-bold mb-12 text-center">{productCopy.whyBundle.title}</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {productCopy.whyBundle.benefits.map((benefit) => (
            <div class="p-6 bg-gray-50 rounded-lg border">
              <svg class="w-10 h-10 text-[var(--color-primary)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <h3 class="font-semibold text-lg mb-2">{benefit.title}</h3>
              <p class="text-gray-600 text-sm">{benefit.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Bundle: Comparison Table -->
    {isBundle && productCopy.comparisonTable && (
      <section class="py-16 bg-gray-50 -mx-4 px-4 rounded-lg">
        <h2 class="text-3xl font-bold mb-8 text-center">{productCopy.comparisonTable.title}</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white rounded-lg text-sm">
            <thead>
              <tr class="border-b-2">
                {productCopy.comparisonTable.headers.map((header) => (
                  <th class="p-4 text-left font-semibold">{header}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {productCopy.comparisonTable.rows.map((row) => (
                <tr class="border-b">
                  {row.map((cell, ci) => (
                    <td class={`p-4 ${ci === 0 ? 'font-medium' : 'text-gray-600'}`}>{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-center text-gray-500 italic mt-6 max-w-2xl mx-auto">{productCopy.comparisonTable.bottomLine}</p>
      </section>
    )}

    <!-- Why It's Designed This Way (non-bundle) -->
    {!isBundle && (
      <section class="py-16">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl font-bold mb-4 text-center">
            {productType === 'Donning Sock' && productCopy.whyItsNeeded ? productCopy.whyItsNeeded.title : 'Adaptive Features That Restore Independence'}
          </h2>

          {(productType === 'Compression Socks' || !productCopy.whyItsNeeded) ? (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
              <div class="space-y-3">
                <svg class="h-12 w-12 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
                <h3 class="text-xl font-semibold">Wide-Mouth Opening</h3>
                <p class="text-gray-600">The opening is 3x wider than standard compression socks. Slide your foot in without forcing, twisting, or needing maximum flexibility.</p>
              </div>
              <div class="space-y-3">
                <svg class="h-12 w-12 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 10-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 013.15 0v1.5m-3.15 0l.075 5.925m3.075-5.925a1.575 1.575 0 013.15 0v1.5m-3.15-1.5v5.925m3.15-4.425a1.575 1.575 0 013.15 0V15m-3.15-3.375v3.375"/></svg>
                <h3 class="text-xl font-semibold">Numbered Guide System</h3>
                <p class="text-gray-600">Built-in numbered markers (#2, #3, blue dot) with textured grip zones. Pull the sock up your leg with less grip strength required. No separate donning aids to buy or store.</p>
              </div>
              <div class="space-y-3">
                <svg class="h-12 w-12 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
                <h3 class="text-xl font-semibold">Graduated Compression Profile</h3>
                <p class="text-gray-600">30 mmHg at the ankle, decreasing to 20 mmHg at the calf. Designed to follow the natural shape of your leg. Firm support without feeling restrictive.</p>
              </div>
              <div class="space-y-3">
                <svg class="h-12 w-12 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 7.5h-.75A2.25 2.25 0 004.5 9.75v7.5a2.25 2.25 0 002.25 2.25h7.5a2.25 2.25 0 002.25-2.25v-7.5a2.25 2.25 0 00-2.25-2.25h-.75m0-3l-3-3m0 0l-3 3m3-3v11.25m6-2.25h.75a2.25 2.25 0 012.25 2.25v7.5a2.25 2.25 0 01-2.25 2.25h-7.5a2.25 2.25 0 01-2.25-2.25v-.75"/></svg>
                <h3 class="text-xl font-semibold">Extended Sizing with Wide-Calf Options</h3>
                <p class="text-gray-600">Standard sizes S through XXL. Wide-calf versions available for larger measurements. Built for real bodies.</p>
              </div>
              <div class="space-y-3">
                <svg class="h-12 w-12 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                <h3 class="text-xl font-semibold">Reinforced Construction</h3>
                <p class="text-gray-600">Extra stitching at stress points. Silicone grip dots at the cuff to help keep them in place. Designed for daily wear, not occasional use.</p>
              </div>
            </div>
          ) : (
            <div class="max-w-3xl mx-auto mt-12 space-y-8">
