---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
---

<BaseLayout
  title="Message Sent, AccessAble"
  description="Your message has been received. We'll get back to you within 24-48 hours."
  noindex={true}
>
  <Header slot="header" />

  <section class="py-24 lg:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
          <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-[#1B2A4A] mb-4">Message Sent</h1>
        <p class="text-lg text-muted-foreground mb-8">
          Thanks for reaching out. We typically respond within 24-48 hours.
        </p>
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-6"
        >
          Back to Home
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
