---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
---

<BaseLayout
  title="AccessAble — Adaptive Compression Socks for Independence"
  description="Compression socks designed for limited mobility, arthritis & post-surgery. DonnEase™ adaptive design for easier independent donning. Free shipping."
>
  <Header slot="header" />

  <!-- Hero + Trust Bar — fill viewport below header -->
  <div class="flex flex-col lg:min-h-[calc(100vh-4rem)]">

    <!-- Hero Section -->
    <section class="relative bg-[#FAF8F3] pt-8 pb-16 lg:flex-1 lg:flex lg:flex-col lg:justify-center lg:py-12">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center">

          <!-- Left Column — Copy -->
          <div class="flex flex-col justify-center">
            <!-- Badge pill -->
            <div class="inline-flex items-center gap-2 bg-gold/10 border border-gold/30 rounded-full px-4 py-1.5 mb-6 w-fit">
              <span class="w-2 h-2 rounded-full bg-gold"></span>
              <span class="text-xs font-semibold tracking-wider text-gold-text uppercase">
                Patent-Pending Adaptive Technology
              </span>
            </div>

            <!-- Headline -->
            <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight mb-6">
              Compression That<br />
              <span class="text-gold">Works With You</span>
            </h1>

            <!-- Body copy — bullet points -->
            <ul class="space-y-3 mb-6 text-lg text-[#374151]">
              <li class="flex items-start gap-2">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#374151]/60 flex-shrink-0"></span>
                Don and doff independently, even with arthritis or limited grip
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#374151]/60 flex-shrink-0"></span>
                Medical-grade 15–30 mmHg graduated compression
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#374151]/60 flex-shrink-0"></span>
                No frames. No separate devices. Just pull on the numbered guides
              </li>
            </ul>

            <!-- Price + Color swatches -->
            <div class="flex items-center gap-6 mb-6">
              <div class="flex items-center gap-3">
                <button
                  data-color="black"
                  data-src="/images/donnease-15-20-black.png"
                  data-alt="DonnEase adaptive compression sock in black"
                  aria-label="Select Black color"
                  class="w-8 h-8 rounded-full border-2 transition-all ring-2 ring-gold ring-offset-2 border-gold bg-gray-900"
                ></button>
                <button
                  data-color="tan"
                  data-src="/images/donnease-15-20-tan.PNG"
                  data-alt="DonnEase adaptive compression sock in tan"
                  aria-label="Select Tan color"
                  class="w-8 h-8 rounded-full border-2 transition-all border-gray-300 hover:border-gray-400 bg-[#D2B48C]"
                ></button>
                <button
                  data-color="white"
                  data-src="/images/donnease-15-20-white.PNG"
                  data-alt="DonnEase adaptive compression sock in white"
                  aria-label="Select White color"
                  class="w-8 h-8 rounded-full border-2 transition-all border-gray-300 hover:border-gray-400 bg-white"
                ></button>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="text-2xl font-bold text-foreground">$39</span>
                <span class="text-sm text-[#374151]">per pair</span>
              </div>
            </div>

            <!-- CTA buttons -->
            <div class="flex flex-col sm:flex-row gap-3 mb-8">
              <a
                href="/collections/all"
                class="inline-flex items-center justify-center h-12 px-8 rounded-md bg-primary text-primary-foreground font-semibold hover:bg-[#C9A84C] hover:text-[#1B2A4A] hover:scale-[1.04] transition-all duration-200 ease-in-out"
              >
                Find Your Fit
              </a>
              <a
                href="/learn/donnease-adaptive-compression-guide"
                class="inline-flex items-center justify-center h-12 px-8 rounded-md border border-primary text-primary font-semibold hover:text-[#C9A84C] hover:bg-transparent transition-all duration-200 ease-in-out"
              >
                How It Works
              </a>
            </div>

            <!-- Spec pills -->
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center bg-gold/10 border border-gold/30 rounded-full px-3 py-1 text-xs font-medium text-gold-text">8-15 to 20-30 mmHg</span>
              <span class="inline-flex items-center bg-gold/10 border border-gold/30 rounded-full px-3 py-1 text-xs font-medium text-gold-text">78% Nylon / 22% Spandex</span>
              <span class="inline-flex items-center bg-gold/10 border border-gold/30 rounded-full px-3 py-1 text-xs font-medium text-gold-text">Made in USA</span>
              <span class="inline-flex items-center bg-gold/10 border border-gold/30 rounded-full px-3 py-1 text-xs font-medium text-gold-text">S–XXL</span>
            </div>
          </div>

          <!-- Right Column — Product Image -->
          <div class="flex flex-col items-center">
            <div class="relative w-full max-w-md aspect-square flex items-center justify-center">
              <div
                class="absolute inset-0 flex items-center justify-center pointer-events-none"
                aria-hidden="true"
              >
                <div
                  class="w-[85%] h-[85%] rounded-full"
                  style="background: radial-gradient(circle, hsl(43 59% 53% / 0.1), hsl(43 59% 53% / 0.05), transparent);"
                ></div>
              </div>
              <img
                id="hero-product-img"
                src="/images/donnease-15-20-black.png"
                alt="DonnEase adaptive compression sock in black"
                class="relative z-10 w-full h-full object-contain drop-shadow-lg"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="py-[72px] bg-white">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 md:gap-x-12 lg:gap-x-16">
          <div class="flex items-center gap-2">
            <!-- Shield icon -->
            <svg class="h-5 w-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span class="text-sm font-medium text-primary whitespace-nowrap">Made in USA — FDA-Licensed Facility</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Lightbulb icon -->
            <svg class="h-5 w-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
            <span class="text-sm font-medium text-primary whitespace-nowrap">Patent-Pending Adaptive Technology</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Heart icon -->
            <svg class="h-5 w-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            <span class="text-sm font-medium text-primary whitespace-nowrap">Medical-Grade Graduated Compression</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Star icon -->
            <svg class="h-5 w-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
            <span class="text-sm font-medium text-primary whitespace-nowrap">Real User Tested — Rated 4.6★ by Wear Testers</span>
          </div>
        </div>
      </div>
    </section>

  </div><!-- end Hero + Trust Bar viewport wrapper -->

  <!-- Featured Products -->
  <section class="py-16 bg-[#FAF8F3]">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8 text-center">Featured Products</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- DonnEase Adaptive -->
        <div class="rounded-lg border bg-card overflow-hidden group">
          <a href="/collections/donnease">
            <div class="aspect-square overflow-hidden bg-muted relative">
              <span class="absolute top-3 left-3 z-10 inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-primary text-primary-foreground">Adaptive Design</span>
              <img
                src="/images/donnease-15-20-black.png"
                alt="AccessAble DonnEase™ Adaptive Compression Sock"
                class="object-cover w-full h-full group-hover:scale-105 transition-transform"
              />
            </div>
          </a>
          <div class="p-4">
            <a href="/collections/donnease">
              <h3 class="font-medium mb-1 hover:text-primary transition-colors">AccessAble DonnEase™ Adaptive Compression Sock</h3>
            </a>
            <p class="text-sm text-[#374151] mb-3">Wide-mouth opening, built-in numbered markers, guided donning system. Put on compression socks independently.</p>
            <div class="flex items-center justify-between">
              <span class="font-bold">$39.00</span>
              <a
                href="https://signup.accessablecompression.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-3 py-1.5 text-sm font-medium hover:bg-primary/90 transition-colors"
              >
                <!-- Mail icon -->
                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Join Waitlist
              </a>
            </div>
          </div>
        </div>

        <!-- Compression Socks (Tan) -->
        <div class="rounded-lg border bg-card overflow-hidden group">
          <a href="/collections/compression-socks">
            <div class="aspect-square overflow-hidden bg-muted relative">
              <img
                src="/images/donnease-15-20-tan.PNG"
                alt="AccessAble Compression Socks (Tan)"
                class="object-cover w-full h-full group-hover:scale-105 transition-transform"
              />
            </div>
          </a>
          <div class="p-4">
            <a href="/collections/compression-socks">
              <h3 class="font-medium mb-1 hover:text-primary transition-colors">AccessAble Compression Socks (Tan)</h3>
            </a>
            <p class="text-sm text-[#374151] mb-3">Medical-grade graduated compression. Available in 15-20 or 20-30 mmHg.</p>
            <div class="flex items-center justify-between">
              <span class="font-bold">$34.00</span>
              <a
                href="https://signup.accessablecompression.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-3 py-1.5 text-sm font-medium hover:bg-primary/90 transition-colors"
              >
                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Join Waitlist
              </a>
            </div>
          </div>
        </div>

        <!-- Starter Kit -->
        <div class="rounded-lg border bg-card overflow-hidden group">
          <a href="/collections/bundles">
            <div class="aspect-square overflow-hidden bg-muted relative">
              <span class="absolute top-3 left-3 z-10 inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-primary text-primary-foreground">Best Value</span>
              <img
                src="/images/donnease-15-20-white.PNG"
                alt="Starter Kit — DonnEase™ + Compression Socks"
                class="object-cover w-full h-full group-hover:scale-105 transition-transform"
              />
            </div>
          </a>
          <div class="p-4">
            <a href="/collections/bundles">
              <h3 class="font-medium mb-1 hover:text-primary transition-colors">Starter Kit — DonnEase™ + Compression Socks</h3>
            </a>
            <p class="text-sm text-[#374151] mb-3">1 DonnEase™ + 1 Standard Compression Sock. Everything you need to get started.</p>
            <div class="flex items-center justify-between">
              <span class="font-bold">$65.00</span>
              <a
                href="https://signup.accessablecompression.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-3 py-1.5 text-sm font-medium hover:bg-primary/90 transition-colors"
              >
                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Join Waitlist
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Feature Highlights Icon Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <!-- Shield icon -->
            <svg class="h-12 w-12 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Medical-Grade Compression</h3>
          <p class="text-sm text-[#374151]">
            Graduated compression technology built to professional standards. FDA-registered manufacturing.
          </p>
        </div>

        <div class="text-center">
          <div class="flex justify-center mb-4">
            <!-- Wrench icon -->
            <svg class="h-12 w-12 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Adaptive Design</h3>
          <p class="text-sm text-[#374151]">
            Wide-mouth opening and built-in numbered markers. Put them on yourself in under 60 seconds.
          </p>
        </div>

        <div class="text-center">
          <div class="flex justify-center mb-4">
            <!-- Clock icon -->
            <svg class="h-12 w-12 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">All-Day Comfort</h3>
          <p class="text-sm text-[#374151]">
            Moisture-wicking nylon-spandex fabric. Reinforced construction. Designed for 12+ hour wear.
          </p>
        </div>

        <div class="text-center">
          <div class="flex justify-center mb-4">
            <!-- Ruler icon -->
            <svg class="h-12 w-12 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 2v20M6 6h4M6 10h8M6 14h4M6 18h6M18 2v20" /></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Extended Sizing</h3>
          <p class="text-sm text-[#374151]">
            S through XXL. Built for real bodies, not just averages.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-center">Independent Comfort in Three Steps</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-[#C9A84C] text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto mb-4">
            1
          </div>
          <h3 class="text-xl font-bold mb-3">Choose Your Compression Level</h3>
          <p class="text-[#374151] mb-4">
            15-20 mmHg for daily support. 20-30 mmHg for post-surgical or as directed by your provider. Unsure?
          </p>
          <a href="/learn" class="text-primary font-medium hover:underline">See our Compression Guide &rarr;</a>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-[#C9A84C] text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto mb-4">
            2
          </div>
          <h3 class="text-xl font-bold mb-3">Find Your Size</h3>
          <p class="text-[#374151] mb-4">
            Measure your calf and ankle circumference. Use our sizing chart for the best fit.
          </p>
          <a href="/size-guide" class="text-primary font-medium hover:underline">Watch our sizing video &rarr;</a>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-[#C9A84C] text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto mb-4">
            3
          </div>
          <h3 class="text-xl font-bold mb-3">Experience the Difference</h3>
          <p class="text-[#374151]">
            Wide opening. Numbered guide system. Comfort that lasts all day.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="py-20 bg-[#F4F1EA]">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Real-World Tested. Purpose-Built for Independence.
        </h2>
        <p class="text-xl text-[#374151] max-w-2xl mx-auto">
          Adaptive compression refined through real-world wear testing with mobility-challenged users.
        </p>
      </div>

      <!-- Design Principles Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 max-w-4xl mx-auto">
        <div class="text-center p-6 bg-white rounded-lg shadow-sm">
          <div class="w-16 h-16 mx-auto mb-4 bg-gold/10 rounded-full flex items-center justify-center">
            <!-- Target icon -->
            <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" /></svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Purpose-Built</h3>
          <p class="text-[#374151] text-sm">
            Designed specifically for limited hand strength and mobility
          </p>
        </div>

        <div class="text-center p-6 bg-white rounded-lg shadow-sm">
          <div class="w-16 h-16 mx-auto mb-4 bg-gold/10 rounded-full flex items-center justify-center">
            <!-- CheckCircle icon -->
            <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-bold text-lg mb-2">User-Tested</h3>
          <p class="text-[#374151] text-sm">
            Refined through real-world wear testing
          </p>
        </div>

        <div class="text-center p-6 bg-white rounded-lg shadow-sm">
          <div class="w-16 h-16 mx-auto mb-4 bg-gold/10 rounded-full flex items-center justify-center">
            <!-- Award icon -->
            <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7" /><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" /></svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Patent Pending</h3>
          <p class="text-[#374151] text-sm">
            Innovative adaptive compression technology
          </p>
        </div>
      </div>

      <!-- Testimonials from Wear Testing -->
      <div class="mb-6">
        <p class="text-center text-sm text-[#374151] mb-8">
          Feedback from wear testing participants
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Testimonial 1: Erica Fraser -->
        <div class="rounded-lg border bg-card p-6">
          <div class="flex items-start gap-4">
            <!-- Quote icon -->
            <svg class="w-8 h-8 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>
            <div>
              <p class="text-[#374151] mb-4">
