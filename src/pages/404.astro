---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
---

<BaseLayout title="Page Not Found — AccessAble" description="The page you're looking for doesn't exist. Return to the AccessAble homepage." noindex={true}>
  <Header slot="header" />
  <div class="flex min-h-[60vh] items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Oops! Page not found</p>
      <a href="/" class="text-primary underline hover:text-primary/90">
        Return to Home
      </a>
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
