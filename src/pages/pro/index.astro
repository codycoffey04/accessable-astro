---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import Breadcrumb from '@/components/astro/Breadcrumb.astro';
---

<BaseLayout title="AccessAble Pro — Premium Compression for Healthcare Professionals" description="Premium compression socks and footies designed for nurses, PTs, OTs, and CNAs who spend 8-12+ hours on their feet. Request bulk pricing and samples.">
  <Header slot="header" />
  <Breadcrumb items={[{ label: 'AccessAble Pro' }]} />

  <div>
    <!-- Hero -->
    <section class="bg-[#FAF8F3] py-20 lg:py-32">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-start">
          <!-- Left Column - Text Content -->
          <div class="flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 bg-gold/10 border border-gold/30 rounded-full px-4 py-1.5 mb-4 w-fit">
              <span class="w-2 h-2 rounded-full bg-gold"></span>
              <span class="text-xs font-semibold tracking-wider text-gold-text uppercase">For Healthcare Professionals</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-bold mb-4">
              All-Day Compression That Keeps Your Clinical Teams Standing
            </h1>
            <p class="text-xl text-[#374151] mb-6">
              8-15 mmHg clinic-grade socks and footies engineered for 12+ hour shifts, industrial laundering, and bulk ordering. Reduce fatigue. Improve retention.
            </p>

            <ul class="grid md:grid-cols-1 gap-3 mb-8 text-left">
              <li class="flex gap-2 text-base">
                <!-- CheckCircle icon -->
                <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span>Clinic-grade durability — Built for daily wear and professional laundering</span>
              </li>
              <li class="flex gap-2 text-base">
                <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span>All-day graduated compression — 8-15 mmHg designed for long shifts</span>
              </li>
              <li class="flex gap-2 text-base">
                <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span>Moisture-wicking performance — Keeps feet dry through double shifts</span>
              </li>
              <li class="flex gap-2 text-base">
                <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span>Seamless toe construction — No irritation points during extended wear</span>
              </li>
              <li class="flex gap-2 text-base">
                <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span>Available in professional colors — Black, navy, white</span>
              </li>
            </ul>

            <div class="flex flex-col sm:flex-row gap-4">
              <a href="https://signup.accessablecompression.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-[#1B2A4A] text-white hover:bg-[#C9A84C] hover:text-[#1B2A4A] transition-all duration-200 ease-in-out text-sm font-medium">Request Bulk Pricing & Samples</a>
              <a href="/pro/login" class="inline-flex items-center justify-center h-12 px-8 rounded-lg border-2 border-[#1B2A4A] text-[#1B2A4A] bg-transparent hover:bg-[#C9A84C] hover:border-[#C9A84C] hover:text-[#1B2A4A] transition-all duration-200 ease-in-out text-sm font-medium">Login to Pro Portal</a>
            </div>

            <div class="mt-8 border border-amber-500 bg-amber-50 rounded-lg p-4 flex items-start gap-3">
              <!-- AlertCircle icon -->
              <svg class="h-4 w-4 text-amber-600 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              <p class="text-sm text-amber-900">
                These products are not intended to diagnose, treat, cure, or prevent any disease. Consult a healthcare professional before starting any compression regimen.
                <a href="/policies/fda-disclaimer" class="underline font-medium">Full Policy →</a>
              </p>
            </div>
          </div>

          <!-- Right Column - Product Image -->
          <div class="flex flex-col items-center justify-center">
            <div class="relative w-full max-w-md aspect-square flex items-center justify-center">
              <div
                class="absolute inset-0 flex items-center justify-center pointer-events-none"
                aria-hidden="true"
              >
                <div
                  class="w-[85%] h-[85%] rounded-full"
                  style="background: radial-gradient(circle, hsl(43 59% 53% / 0.1), hsl(43 59% 53% / 0.05), transparent)"
                ></div>
              </div>
              <img
                src="/images/donnease-15-20-black.png"
                alt="AccessAble Pro compression sock in black"
                class="relative z-10 w-full h-full object-contain drop-shadow-lg"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sub-navigation -->
    <div class="bg-[#FAF8F3] pb-8">
      <nav class="flex items-center justify-center flex-wrap gap-3" aria-label="Pro section navigation">
        <a href="/pro/bulk" class="inline-flex items-center justify-center h-11 px-6 text-sm font-semibold border-2 border-[#1B2A4A] text-[#1B2A4A] bg-transparent hover:bg-[#C9A84C] hover:border-[#C9A84C] hover:text-[#1B2A4A] transition-all duration-200 rounded-full">Bulk & Team Ordering</a>
        <div class="w-px h-8 bg-[#1B2A4A]/20 hidden sm:block"></div>
        <a href="/pro/login" class="inline-flex items-center gap-2 justify-center h-11 px-6 text-sm font-semibold border-2 border-[#1B2A4A] text-[#1B2A4A] bg-transparent hover:bg-[#C9A84C] hover:border-[#C9A84C] hover:text-[#1B2A4A] transition-all duration-200 rounded-full">Pro Portal Login <span class="text-xs font-normal text-[#374151]/60">(Coming Soon)</span></a>
        <div class="w-px h-8 bg-[#1B2A4A]/20 hidden sm:block"></div>
        <a href="/pro/resources" class="inline-flex items-center justify-center h-11 px-6 text-sm font-semibold border-2 border-[#1B2A4A] text-[#1B2A4A] bg-transparent hover:bg-[#C9A84C] hover:border-[#C9A84C] hover:text-[#1B2A4A] transition-all duration-200 rounded-full">Clinical Resources & Sizing</a>
      </nav>
    </div>

    <!-- Trust Badges -->
    <section class="bg-white py-[72px]">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16">
          <div class="flex items-center gap-3">
            <div class="bg-gold/10 rounded-full w-10 h-10 flex items-center justify-center">
              <!-- Shield icon -->
              <svg class="h-5 w-5 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            </div>
            <span class="text-sm font-semibold text-[#1B2A4A]">FDA-Registered Facility</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="bg-gold/10 rounded-full w-10 h-10 flex items-center justify-center">
              <!-- Award icon -->
              <svg class="h-5 w-5 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <span class="text-sm font-semibold text-[#1B2A4A]">Made in USA</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="bg-gold/10 rounded-full w-10 h-10 flex items-center justify-center">
              <!-- Zap icon -->
              <svg class="h-5 w-5 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
            </div>
            <span class="text-sm font-semibold text-[#1B2A4A]">Patent-Pending DonnEase™ Technology</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="bg-gold/10 rounded-full w-10 h-10 flex items-center justify-center">
              <!-- CheckCircle icon -->
              <svg class="h-5 w-5 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            </div>
            <span class="text-sm font-semibold text-[#1B2A4A]">Clinic-Grade Graduated Compression</span>
          </div>
        </div>
      </div>
    </section>

    <!-- What Makes AccessAble Pro Different -->
    <section class="py-16 bg-[#F4F1EA]">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold mb-4">What Makes AccessAble Pro Different</h2>
          <p class="text-xl text-[#374151]">Designed by someone who knows what it means to need better socks</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <!-- Feature 1: Independent Donning Design -->
          <div class="rounded-xl border border-gray-200 bg-card text-card-foreground shadow-sm hover:border-[#C9A84C] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
            <div class="px-8 py-10">
              <div class="bg-gold/10 rounded-full w-12 h-12 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Independent Donning Design</h3>
              <p class="text-sm text-[#374151]">
                Easy on, easy off — even when you're exhausted after a 12-hour shift. Wide-mouth opening and numbered guide system mean no wrestling with your socks at 5 AM.
              </p>
            </div>
          </div>

          <!-- Feature 2: Size Range for Every Professional -->
          <div class="rounded-xl border border-gray-200 bg-card text-card-foreground shadow-sm hover:border-[#C9A84C] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
            <div class="px-8 py-10">
              <div class="bg-gold/10 rounded-full w-12 h-12 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Size Range for Every Professional</h3>
              <p class="text-sm text-[#374151]">
                S through XXL with wide-calf options. One size does not fit all — and neither should your compression socks.
              </p>
            </div>
          </div>

          <!-- Feature 3: Clinic-Grade Durability -->
          <div class="rounded-xl border border-gray-200 bg-card text-card-foreground shadow-sm hover:border-[#C9A84C] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
            <div class="px-8 py-10">
              <div class="bg-gold/10 rounded-full w-12 h-12 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Clinic-Grade Durability</h3>
              <p class="text-sm text-[#374151]">
                Reinforced stitching at stress points. Designed for professional laundering cycles. Holds compression efficacy through repeated wash cycles.
              </p>
            </div>
          </div>

          <!-- Feature 4: All-Day Comfort -->
          <div class="rounded-xl border border-gray-200 bg-card text-card-foreground shadow-sm hover:border-[#C9A84C] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
            <div class="px-8 py-10">
              <div class="bg-gold/10 rounded-full w-12 h-12 flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">All-Day Comfort</h3>
              <p class="text-sm text-[#374151]">
                Moisture-wicking nylon-spandex blend keeps feet dry. Seamless toe construction eliminates irritation points. Graduated 8-15 mmHg compression supports you without squeezing.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Need Socks for Your Whole Team? -->
    <section class="py-16 bg-[#FAF8F3] mt-[120px]">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-6">Need Socks for Your Whole Team?</h2>
          <p class="text-xl text-[#374151] mb-8">
            We offer team discounts for practices and departments ordering 10+ pairs. Contact us for group pricing.
          </p>
          <a href="/contact" class="inline-flex items-center justify-center h-12 px-8 bg-primary text-primary-foreground hover:bg-[#C9A84C] hover:text-[#1B2A4A] hover:scale-[1.04] transition-all duration-200 ease-in-out rounded-md text-sm font-medium">Contact Us About Team Orders</a>
        </div>
      </div>
    </section>

    <!-- Frequently Asked Questions -->
    <section class="py-16 bg-white mt-[120px]">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold mb-12 text-center">Frequently Asked Questions</h2>

        <div class="w-full">
          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>What compression level are AccessAble Pro socks?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                AccessAble Pro socks provide 8-15 mmHg graduated compression — the gentle, all-day level designed for professionals on their feet during long shifts. This level supports healthy circulation without feeling restrictive during 8-12+ hour workdays.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>What sizes are available?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                AccessAble Pro is available in S, M, L, XL, and XXL with wide-calf options. Short and tall leg length variants ensure the right fit for every body type. See our size guide for detailed measurements.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>How do I wash AccessAble Pro socks?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                Machine wash cold, tumble dry low. AccessAble Pro socks are built for professional laundering — they maintain compression efficacy through repeated wash cycles. We recommend having 2-3 pairs in rotation for daily wear.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>When will AccessAble Pro be available?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                AccessAble Pro is launching in 2026. Request bulk pricing and samples to secure early access and launch-day rates. We're currently in our wear testing phase with 40-50 active testers.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>Do you offer team or group discounts?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                Yes. We offer team discounts for practices and departments ordering 10+ pairs. Contact us for group pricing — we'll work with your team to get the right sizes for everyone.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>Are these FSA/HSA eligible?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                Compression socks are generally FSA/HSA eligible. We're working with TrueMed to offer seamless HSA/FSA checkout at launch. Check with your plan administrator for specific coverage details.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>What colors are available?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                AccessAble Pro launches in black, navy, and white — professional colors that work with any scrubs or clinical attire.
              </p>
            </div>
          </details>

          <details class="group border-b">
            <summary class="flex items-center justify-between w-full py-4 text-left font-medium cursor-pointer hover:underline [&::-webkit-details-marker]:hidden list-none">
              <span>What makes these different from regular compression socks?</span>
              <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pb-4">
              <p class="text-[#374151]">
                AccessAble Pro features our adaptive DonnEase™ design — a wide-mouth opening with built-in numbered markers that makes putting on and taking off compression socks significantly easier, especially when you're tired after a long shift. Plus clinic-grade durability, moisture-wicking nylon-spandex blend, and seamless toe construction built specifically for healthcare professionals.
              </p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- Waitlist CTA -->
    <section class="py-16 bg-[#1B2A4A] mt-[120px]">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-4 text-white">Request Bulk Pricing & Samples</h2>
          <p class="text-lg text-white/80 mb-8">
            Get volume pricing for your clinic, department, or facility. Early partners get priority access and launch-day rates.
          </p>
